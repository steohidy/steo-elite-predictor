# ================================================
# Configuration Base de Données (PostgreSQL)
# ================================================
# URL de connexion avec pooler (pour serverless)
DATABASE_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require"

# URL directe sans pooler (pour migrations Prisma)
DIRECT_DATABASE_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require"

# ================================================
# API Externes
# ================================================
# The Odds API - Cotes sportives en temps réel
# Obtenir une clé: https://the-odds-api.com/
THE_ODDS_API_KEY="votre_cle_api_ici"

# RapidAPI (optionnel - pour d'autres sources de données)
RAPIDAPI_KEY="votre_cle_rapidapi_ici"

# ================================================
# Configuration Application
# ================================================
# URL publique de l'application (Vercel la fournit automatiquement)
NEXT_PUBLIC_APP_URL="https://votre-projet.vercel.app"

# ================================================
# Authentification (optionnel - pour NextAuth.js)
# ================================================
NEXTAUTH_SECRET="generer_avec_openssl_rand_base64_32"
NEXTAUTH_URL="https://votre-projet.vercel.app"
